# --- Telegram ---
# Get this from @BotFather (see README step-by-step)
TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenReplaceMe

# Default channel used for all categories if per-category channels below are blank.
# Use @channelusername for public channels, or the numeric -100xxxxxxxxxx id for private ones.
TELEGRAM_CHANNEL_ID=@arthavidhi_market_news

# Optional: route each category to its own channel/topic.
# Leave blank to fall back to TELEGRAM_CHANNEL_ID above.
TELEGRAM_CHANNEL_RESULTS=
TELEGRAM_CHANNEL_CORP_ACTION=
TELEGRAM_CHANNEL_STOCK_NEWS=

# --- Polling ---
# How often (seconds) to poll each exchange for new announcements.
POLL_INTERVAL_SECONDS=45

# --- Storage ---
# SQLite file used to remember which announcements were already sent.
DEDUP_DB_PATH=./data/seen_announcements.db

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=./data/news_bot.log

# --- BSE / NSE library internals ---
# Folder the underlying nse/bse libraries use to cache cookies + downloads.
LIB_DOWNLOAD_FOLDER=./data/cache
